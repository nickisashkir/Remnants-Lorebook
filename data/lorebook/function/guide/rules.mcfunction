give @s minecraft:written_book[custom_data={guide:true},written_book_content={title:"Server Rules",author:"The Remnants",pages:[[{"text":"Server Rules\n","color":"dark_green","bold":true},{"text":"[Back to Guide]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger guide.nav set 1"}},{"text":"\n"},{"text":"Full rules at:\ntheremnants.gg/rules\n\n","color":"dark_aqua"},{"text":"Here's the short version.\n","color":"#6B4226","italic":true}],[{"text":"Rules\n","color":"dark_green","bold":true},{"text":"[Back to Guide]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger guide.nav set 1"}},{"text":"\n"},{"text":"Community\n","color":"dark_red","bold":true},{"text":"1. Ages 21+ only.\n\n2. No bigotry.\n\n3. No cheating.\n","color":"#6B4226"}],[{"text":"Rules\n","color":"dark_green","bold":true},{"text":"[Back to Guide]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger guide.nav set 1"}},{"text":"\n"},{"text":"Building\n","color":"dark_red","bold":true},{"text":"4. PvP is consent-only.\n\n5. Build 100+ blocks from neighbors (or ask).\n\n6. No floating trees.\n","color":"#6B4226"}],[{"text":"Rules\n","color":"dark_green","bold":true},{"text":"[Back to Guide]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger guide.nav set 1"}},{"text":"\n"},{"text":"Shared Spaces\n","color":"dark_red","bold":true},{"text":"7. Keep builds tidy.\n\n8. Ice Lands = reserved for community events.\n","color":"#6B4226"}],[{"text":"Rules\n","color":"dark_green","bold":true},{"text":"[Back to Guide]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger guide.nav set 1"}},{"text":"\n"},{"text":"9. Use the Wither Chamber in the shopping district.\n\n","color":"#6B4226"},{"text":"10. Don't destroy Ancient City chests — loot them so they regen.\n","color":"#6B4226"}],[{"text":"Rules\n","color":"dark_green","bold":true},{"text":"[Back to Guide]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger guide.nav set 1"}},{"text":"\n"},{"text":"Resources\n","color":"dark_red","bold":true},{"text":"11. Don't use others' farms without permission.\n\n12. Don't sell items from public farms.\n","color":"#6B4226"}],[{"text":"Rules\n","color":"dark_green","bold":true},{"text":"[Back to Guide]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger guide.nav set 1"}},{"text":"\n"},{"text":"Other\n","color":"dark_red","bold":true},{"text":"13. Inactive builds may reset after 90 days. Tell an admin if away.\n","color":"#6B4226"}],[{"text":"Rules\n","color":"dark_green","bold":true},{"text":"[Back to Guide]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger guide.nav set 1"}},{"text":"\n"},{"text":"14. No required client mods for gameplay.\n\n15. End duping is not currently allowed.\n","color":"#6B4226"}]]}] 1
