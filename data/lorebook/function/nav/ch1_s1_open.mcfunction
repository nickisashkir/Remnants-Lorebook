give @s minecraft:written_book[written_book_content={title:"The Terren People",author:"The Archivists",pages:[[{"text":"The Terren People\n","color":"dark_red","bold":true},{"text":"[Back to Chapter I]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger lorebook.nav set 10"}},{"text":"\n"},{"text":"Long before any living civilization claimed the Overworld, another people had already built their greatest cities.\n\n","color":"#6B4226"},{"text":"They mapped every river of a continent now buried beneath centuries of earth.\n","color":"#6B4226"}],[{"text":"The Terren People\n","color":"dark_red","bold":true},{"text":"[Back to Chapter I]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger lorebook.nav set 10"}},{"text":"\n"},{"text":"They called themselves the Terren.\n\n","color":"#6B4226"},{"text":"A word meaning 'those of the earth.'\n\n","color":"#6B4226"},{"text":"In older dialects, simply 'the ones who remain.'\n","color":"#6B4226","italic":true}],[{"text":"The Terren People\n","color":"dark_red","bold":true},{"text":"[Back to Chapter I]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger lorebook.nav set 10"}},{"text":"\n"},{"text":"They were not the first people.\n\n","color":"#6B4226"},{"text":"But they were the first to build something that outlasted them.\n\n","color":"#6B4226"},{"text":"Their roads and sealed chambers survive. Their names do not.\n","color":"#6B4226","italic":true}],[{"text":"The Terren People\n","color":"dark_red","bold":true},{"text":"[Back to Chapter I]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger lorebook.nav set 10"}},{"text":"\n"},{"text":"\"The sherds do not lie.\n\nSomeone lived here. Someone thrived here.\"\n\n","color":"dark_gray","italic":true},{"text":"— Chief Researcher Aldyn","color":"dark_gray","italic":true}]]}] 1
