give @s minecraft:written_book[written_book_content={title:"Masters of Clay",author:"The Archivists",pages:[[{"text":"Masters of Clay\n","color":"dark_red","bold":true},{"text":"[Back to Chapter I]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger lorebook.nav set 10"}},{"text":"\n"},{"text":"To the Terren, clay was not merely a material.\n\n","color":"#6B4226"},{"text":"It was the medium of civilization itself.\n","color":"#6B4226"}],[{"text":"Masters of Clay\n","color":"dark_red","bold":true},{"text":"[Back to Chapter I]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger lorebook.nav set 10"}},{"text":"\n"},{"text":"They built their cities from it.\n\n","color":"#6B4226"},{"text":"And they recorded their entire history not in scrolls, but in pottery.\n","color":"#6B4226"}],[{"text":"Masters of Clay\n","color":"dark_red","bold":true},{"text":"[Back to Chapter I]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger lorebook.nav set 10"}},{"text":"\n"},{"text":"Each vessel was a chapter.\n\n","color":"#6B4226"},{"text":"Each sherd a sentence.\n","color":"#6B4226"}],[{"text":"Masters of Clay\n","color":"dark_red","bold":true},{"text":"[Back to Chapter I]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger lorebook.nav set 10"}},{"text":"\n"},{"text":"\"A sherd is not decoration.\n\nIt is a page torn from a book no one has yet learned to read.\"\n","color":"#6B4226","italic":true}]]}] 1
