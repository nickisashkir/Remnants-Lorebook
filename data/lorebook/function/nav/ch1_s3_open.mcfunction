give @s minecraft:written_book[written_book_content={title:"The Terren Language",author:"The Archivists",pages:[[{"text":"The Terren Language\n","color":"dark_red","bold":true},{"text":"[Back to Chapter I]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger lorebook.nav set 10"}},{"text":"\n"},{"text":"After extensive study of recovered sherds, researchers have begun to decode the Terren pictographic system.\n","color":"#6B4226"}],[{"text":"The Terren Language\n","color":"dark_red","bold":true},{"text":"[Back to Chapter I]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger lorebook.nav set 10"}},{"text":"\n"},{"text":"Each symbol represents a concept rather than a sound.\n\n","color":"#6B4226"},{"text":"This is why sherds appear decorative to untrained eyes.\n","color":"#6B4226"}],[{"text":"The Terren Language\n","color":"dark_red","bold":true},{"text":"[Back to Chapter I]\n","color":"dark_aqua","underlined":true,"click_event":{"action":"run_command","command":"/trigger lorebook.nav set 10"}},{"text":"\n"},{"text":"They are dense with meaning.\n\n","color":"#6B4226","italic":true},{"text":"Translation is ongoing. New sherds may expand the known lexicon.\n","color":"dark_blue","italic":true}]]}] 1
